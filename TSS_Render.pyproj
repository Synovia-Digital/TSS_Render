    <Name>TSS_Render</Name>
    <RootNamespace>TSS_Render</RootNamespace>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="TSS_Render.py" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="live\" />
    <Folder Include="live\.streamlit\" />
    <Folder Include="live\assets\" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="live\.streamlit\config.toml" />
    <Content Include="live\assets\FusionLogo.jpg" />
    <Content Include="live\assets\PrimelineExpress.png" />
    <Content Include="live\assets\SynoviaLogoHor.jpg" />
    <Content Include="live\Dockerfile" />
    <Content Include="live\render.yaml" />
    <Content Include="live\requirements.txt" />
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
